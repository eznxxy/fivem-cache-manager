{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for FiveM Cache Manager main window",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://servers.fivem.net/**",
      "https://servers.fivem.net",
      "https://*.fivem.net/**",
      "https://*.cfx.re/**",
      "https://cfx.re/**"
    ]
  },
  "permissions": [
    "app-commands",
    "allow-swapcache",
    "allow-loadconfig",
    "allow-saveconfig",
    "allow-getserverfolders",
    "allow-serverselected",
    "allow-checkcache",
    "core:default",
    "opener:default",
    "shell:allow-open",
    "dialog:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}
